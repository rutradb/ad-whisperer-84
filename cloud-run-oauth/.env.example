# Google Cloud Console > Credentials > OAuth Client ID
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-your-client-secret

# Google Ads > Ferramentas > Central de API > Developer Token
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# URL do seu app no Lovable (sem barra no final)
ALLOWED_ORIGIN=https://seu-app.lovable.app

# ID do MCC (opcional, para contas gerenciadas)
LOGIN_CUSTOMER_ID=

# Porta (Cloud Run usa 8080 por padrao)
PORT=8080
